<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOGS" value="C://logs" />           <!--C://logs is where the log file will be generated -->

    <appender name="Console"
              class="ch.qos.logback.core.ConsoleAppender">
        <layout class="ch.qos.logback.classic.PatternLayout">
            <Pattern>
                %black(%d{ISO8601}) %highlight(%-5level) [%blue(%t)] %yellow(%C{1}): %msg%n%throwable
            </Pattern>
        </layout>
    </appender>

    <appender name="RollingFile"
              class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS}/spring-boot-logger.log</file>      // the file name inside C://logs is spring-boot-logger.log
        <encoder
                class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <Pattern>%d %p %C{1} [%t] %m%n</Pattern>
        </encoder>

        <rollingPolicy
                class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- rollover daily and when the file reaches 10 MegaBytes, here {LOGS} is in line 4 -->
            <fileNamePattern>${LOGS}/archived/spring-boot-logger-%d{yyyy-MM-dd}.%i.log  <!-- This i value will increase with each log file generated eg 1,2,3 -->
            </fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy
                    class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>10MB</maxFileSize>         <!-- after the previously created log file size exceeds 10MB, it'll move to new archive folder inside C://logs and new file would be generated -->
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
    </appender>

    <!-- LOG everything at INFO level, framework related logging and also for custom packages -->
    <root level="info">
        <appender-ref ref="RollingFile" />
        <appender-ref ref="Console" />
    </root>

    <!-- LOG "com.learnspring.nexusacademy.*" at ERROR level -->
    <logger name="com.learnspring.nexusacademy" level="error" additivity="false">
        <appender-ref ref="RollingFile" />   <!-- log it in the file -->
        <appender-ref ref="Console" />      <!-- Also log it in the console -->
    </logger>

</configuration>